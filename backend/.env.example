APP_ENV=development
# Credentialed session cookies require explicit, comma-separated frontend origins.
FRONTEND_ORIGINS=http://localhost:5173,https://real-door-theta.vercel.app

SUPABASE_URL=https://tcdefmeuaeuvsplvihgm.supabase.co
SUPABASE_SECRET_KEY=PASTE_NEW_SECRET_KEY_HERE

DATABASE_URL=PASTE_TRANSACTION_POOLER_URL_HERE
DIRECT_DATABASE_URL=PASTE_DIRECT_URL_HERE

SUPABASE_DOCUMENT_BUCKET=renter-documents
SUPABASE_PACKET_BUCKET=readiness-packets

OPENROUTER_API_KEY=PASTE_NEW_KEY_HERE
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_FREE_MODELS_ONLY=true
OPENROUTER_CHAT_MODEL=openrouter/free

NVIDIA_API_KEY=PASTE_NVIDIA_KEY_HERE
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_RETRIEVAL_BASE_URL=https://ai.api.nvidia.com/v1/retrieval
NVIDIA_CHAT_MODEL=nvidia/nemotron-3-nano-30b-a3b
NVIDIA_STRONG_MODEL=nvidia/nemotron-3-super-120b-a12b
NVIDIA_EMBEDDING_MODEL=nvidia/llama-nemotron-embed-1b-v2
NVIDIA_EMBEDDING_DIMENSIONS=1024
NVIDIA_RERANK_MODEL=nvidia/llama-nemotron-rerank-1b-v2
NVIDIA_OCR_ENABLED=true
NVIDIA_OCR_MODEL=nvidia/nemotron-ocr-v2

# Development defaults to an in-memory repository until migrations are applied.
USE_IN_MEMORY_REPOSITORY=true
SESSION_COOKIE_NAME=realdoor_session

SESSION_TTL_MINUTES=60
PACKET_TTL_MINUTES=60
MAX_UPLOAD_MB=50
MAX_DOCUMENT_PAGES=50
